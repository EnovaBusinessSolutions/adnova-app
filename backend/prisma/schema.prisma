generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  META
  GOOGLE
  TIKTOK
}

enum ConnectionStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}

enum DedupStatus {
  SINGLE
  BROWSER_ONLY
  SERVER_ONLY
  DEDUPLICATED
}

enum AccountPlatform {
  SHOPIFY
  WOOCOMMERCE
  MAGENTO
  CUSTOM
  OTHER
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum WorkspaceIcon {
  SHOPPING_BAG
  LIGHTNING
  TARGET
  ROCKET
  LIGHTBULB
  FIRE
  LEAF
  DIAMOND
}

enum IndustryVertical {
  ECOMMERCE_FASHION
  ECOMMERCE_BEAUTY
  ECOMMERCE_HOME_DECOR
  ECOMMERCE_FOOD_BEVERAGE
  ECOMMERCE_HEALTH_WELLNESS
  ECOMMERCE_ELECTRONICS
  ECOMMERCE_BABY_KIDS
  ECOMMERCE_PETS
  ECOMMERCE_SPORTS_OUTDOORS
  ECOMMERCE_JEWELRY
  ECOMMERCE_AUTOMOTIVE
  DTC_SUBSCRIPTION
  AGENCY
  MARKETPLACE
  OTHER
}

enum PrimaryFocus {
  FOUNDER_CEO
  HEAD_OF_GROWTH
  HEAD_OF_MARKETING
  MARKETING_MANAGER
  PERFORMANCE_MARKETER
  ANALYTICS
  AGENCY
  ENGINEERING
  OTHER
}

model Account {
  id          String          @id @default(uuid())
  accountId   String          @unique @map("account_id")
  domain      String
  platform    AccountPlatform @default(CUSTOM)
  accessToken String?         @map("access_token")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  platformConnections   PlatformConnection[]
  identityGraphs        IdentityGraph[]
  sessions              Session[]
  checkoutSessionMaps   CheckoutSessionMap[]
  events                Event[]
  orders                Order[]
  snapshot              MerchantSnapshot?
  sessionRecordings     SessionRecording[]
  sessionPackets        SessionPacket[]
  people                Person[]
  abandonmentRiskScores AbandonmentRiskScore[]
  abandonmentCohorts    AbandonmentCohort[]

  @@index([workspaceId])
  @@map("accounts")
}

model PlatformConnection {
  id          String           @id @default(uuid())
  accountId   String           @map("account_id")
  platform    Platform
  accessToken String           @map("access_token")
  pixelId     String?          @map("pixel_id")
  adAccountId String?          @map("ad_account_id")
  status      ConnectionStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@unique([accountId, platform])
  @@map("platform_connections")
}

model IdentityGraph {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  userKey         String   @map("user_key")
  customerId      String?  @map("customer_id")
  emailHash       String?  @map("email_hash")
  phoneHash       String?  @map("phone_hash")
  ipHash          String?  @map("ip_hash")
  fbp             String?
  fbc             String?
  fbclid          String?
  gclid           String?
  ttclid          String?
  fingerprintHash String?  @map("fingerprint_hash")
  confidenceScore Float    @map("confidence_score")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @updatedAt @map("last_seen_at")
  deviceCount     Int      @default(1) @map("device_count")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, userKey])
  @@index([accountId, fingerprintHash])
  @@index([accountId, customerId])
  @@map("identity_graph")
}

model Session {
  id                 String    @id @default(uuid())
  sessionId          String    @unique @map("session_id")
  accountId          String    @map("account_id")
  userKey            String    @map("user_key")
  ga4SessionSource   String?   @map("ga4_session_source")
  utmSource          String?   @map("utm_source")
  utmMedium          String?   @map("utm_medium")
  utmCampaign        String?   @map("utm_campaign")
  utmContent         String?   @map("utm_content")
  utmTerm            String?   @map("utm_term")
  referrer           String?
  landingPageUrl     String?   @map("landing_page_url")
  ipHash             String?   @map("ip_hash")
  fbclid             String?
  gclid              String?
  ttclid             String?
  fbp                String?
  fbc                String?
  isFirstTouch       Boolean   @map("is_first_touch")
  startedAt          DateTime  @default(now()) @map("started_at")
  sessionEndAt       DateTime? @map("session_end_at")
  lastEventAt        DateTime  @default(now()) @updatedAt @map("last_event_at")
  claritySessionId   String?   @map("clarity_session_id")
  clarityPlaybackUrl String?   @map("clarity_playback_url")
  rrwebRecordingId   String?   @map("rrweb_recording_id")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@map("sessions")
}

model CheckoutSessionMap {
  id                  String   @id @default(uuid())
  checkoutToken       String   @unique @map("checkout_token")
  accountId           String   @map("account_id")
  sessionId           String   @map("session_id")
  userKey             String   @map("user_key")
  attributionSnapshot Json     @map("attribution_snapshot")
  eventId             String   @map("event_id")
  createdAt           DateTime @default(now()) @map("created_at")
  expiresAt           DateTime @map("expires_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@map("checkout_session_map")
}

model Event {
  id                String    @id @default(uuid())
  eventId           String    @unique @map("event_id")
  accountId         String    @map("account_id")
  sessionId         String    @map("session_id")
  userKey           String    @map("user_key")
  eventName         String    @map("event_name")
  pageType          String?   @map("page_type")
  pageUrl           String?   @map("page_url")
  productId         String?   @map("product_id")
  variantId         String?   @map("variant_id")
  cartId            String?   @map("cart_id")
  cartValue         Float?    @map("cart_value")
  checkoutToken     String?   @map("checkout_token")
  orderId           String?   @map("order_id")
  rawSource         String?   @map("raw_source")
  matchType         String?   @map("match_type")
  confidenceScore   Float?    @map("confidence_score")
  ipHash            String?   @map("ip_hash")
  revenue           Float?
  currency          String?
  items             Json?
  rawPayload        Json      @map("raw_payload")
  collectedAt       DateTime? @map("collected_at")
  browserReceivedAt DateTime? @map("browser_received_at")
  serverReceivedAt  DateTime? @map("server_received_at")
  capturedAt        DateTime? @map("captured_at") // client clock at event-fire moment (ordering source of truth)
  seq               Int? // monotonic per-session sequence for tie-breaking
  postPurchase      Boolean   @default(false) @map("post_purchase")
  createdAt         DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, sessionId, capturedAt])
  @@map("events")
}

model Order {
  id                  String   @id @default(uuid())
  orderId             String   @unique @map("order_id")
  orderNumber         String   @map("order_number")
  accountId           String   @map("account_id")
  checkoutToken       String?  @map("checkout_token")
  userKey             String?  @map("user_key")
  sessionId           String?  @map("session_id")
  customerId          String?  @map("customer_id")
  emailHash           String?  @map("email_hash")
  phoneHash           String?  @map("phone_hash")
  revenue             Float
  subtotal            Float
  discountTotal       Float    @map("discount_total")
  shippingTotal       Float    @map("shipping_total")
  taxTotal            Float    @map("tax_total")
  refundAmount        Float    @default(0) @map("refund_amount")
  chargebackFlag      Boolean  @default(false) @map("chargeback_flag")
  ordersCount         Int?     @map("orders_count")
  currency            String
  lineItems           Json     @map("line_items")
  attributedChannel   String?  @map("attributed_channel")
  attributedCampaign  String?  @map("attributed_campaign")
  attributedAdset     String?  @map("attributed_adset")
  attributedAd        String?  @map("attributed_ad")
  attributedClickId   String?  @map("attributed_click_id")
  attributionModel    String   @default("last_touch") @map("attribution_model")
  attributionSnapshot Json?    @map("attribution_snapshot")
  confidenceScore     Float?   @map("confidence_score")
  eventId             String?  @map("event_id")
  capiSentMeta        Boolean  @default(false) @map("capi_sent_meta")
  capiSentGoogle      Boolean  @default(false) @map("capi_sent_google")
  capiSentTiktok      Boolean  @default(false) @map("capi_sent_tiktok")
  capiMetaResponse    Json?    @map("capi_meta_response")
  capiGoogleResponse  Json?    @map("capi_google_response")
  createdAt           DateTime @default(now()) @map("created_at")
  platformCreatedAt   DateTime @map("platform_created_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@map("orders")
}

model EventDedup {
  eventId           String      @id @map("event_id")
  accountId         String      @map("account_id")
  orderId           String?     @map("order_id")
  eventName         String      @map("event_name")
  browserReceivedAt DateTime?   @map("browser_received_at")
  serverReceivedAt  DateTime?   @map("server_received_at")
  capiSentAt        DateTime?   @map("capi_sent_at")
  dedupStatus       DedupStatus @map("dedup_status")

  @@map("event_dedup")
}

model MerchantSnapshot {
  id        String   @id @default(uuid())
  accountId String   @unique @map("account_id")
  snapshot  Json
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@map("merchant_snapshots")
}

model FailedJob {
  id          String    @id @default(uuid())
  jobType     String    @map("job_type")
  payload     Json
  error       String
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  nextRetryAt DateTime? @map("next_retry_at")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("failed_jobs")
}

// ─── BRI: Behavioral Revenue Intelligence ────────────────────────────────────

enum RecordingStatus {
  RECORDING
  FINALIZING
  READY
  ERROR
}

enum RecordingOutcome {
  PURCHASED
  ABANDONED
  STILL_BROWSING
}

model SessionRecording {
  id                  String            @id @default(uuid())
  recordingId         String            @unique @map("recording_id")
  accountId           String            @map("account_id")
  sessionId           String            @map("session_id")
  userKey             String            @map("user_key")
  triggerEvent        String            @default("add_to_cart") @map("trigger_event")
  triggerAt           DateTime          @map("trigger_at")
  cartValue           Float?            @map("cart_value")
  checkoutToken       String?           @map("checkout_token")
  attributionSnapshot Json?             @map("attribution_snapshot")
  r2Key               String?           @map("r2_key")
  r2ChunksPrefix      String?           @map("r2_chunks_prefix")
  r2Bucket            String?           @map("r2_bucket")
  durationMs          Int?              @map("duration_ms")
  chunkCount          Int               @default(0) @map("chunk_count")
  lastChunkAt         DateTime?         @map("last_chunk_at")
  sizeBytes           BigInt?           @map("size_bytes")
  status              RecordingStatus   @default(RECORDING)
  outcome             RecordingOutcome?
  outcomeAt           DateTime?         @map("outcome_at")
  orderId             String?           @map("order_id")
  deviceType          String?           @map("device_type")
  behavioralSignals   Json?             @map("behavioral_signals")
  rawErasedAt         DateTime?         @map("raw_erased_at")
  maskingEnabled      Boolean           @default(true) @map("masking_enabled")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, sessionId])
  @@index([accountId, status])
  @@index([accountId, outcome])
  @@index([accountId, userKey])
  @@map("session_recordings")
}

model AbandonmentRiskScore {
  id            String   @id @default(uuid())
  sessionId     String   @unique @map("session_id")
  accountId     String   @map("account_id")
  userKey       String   @map("user_key")
  riskScore     Int      @map("risk_score")
  riskFactors   Json     @map("risk_factors")
  cartValue     Float?   @map("cart_value")
  checkoutToken String?  @map("checkout_token")
  computedAt    DateTime @default(now()) @map("computed_at")
  expiresAt     DateTime @map("expires_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, riskScore])
  @@index([accountId, computedAt])
  @@map("abandonment_risk_scores")
}

model AbandonmentCohort {
  id                 String   @id @default(uuid())
  cohortKey          String   @map("cohort_key")
  accountId          String   @map("account_id")
  label              String
  sessionCount       Int      @default(0) @map("session_count")
  avgCartValue       Float?   @map("avg_cart_value")
  commonSignals      Json     @map("common_signals")
  sampleRecordingIds Json     @map("sample_recording_ids")
  computedAt         DateTime @default(now()) @map("computed_at")
  dateRange          Json     @map("date_range")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@unique([accountId, cohortKey])
  @@index([accountId, computedAt])
  @@map("abandonment_cohorts")
}

// ─── BRI Phase 4: SessionPacket ──────────────────────────────────────────────
// Structured behavioral JSON per session — the permanent artifact produced by
// the processing pipeline (keyframes + signals + ecommerce events). Raw rrweb
// streams are erased 24h after this row is written.
//
// Keyed by sessionId (one packet per session, not per recording). Recordings
// fragmented across page loads collapse into one packet here.

enum SessionOutcome {
  PURCHASED
  ABANDONED
  BOUNCED
  STILL_BROWSING
}

model SessionPacket {
  id              String         @id @default(uuid())
  sessionId       String         @unique @map("session_id")
  accountId       String         @map("account_id")
  visitorId       String?        @map("visitor_id")
  personId        String?        @map("person_id") // set by identity resolver (Phase 7)
  startTs         DateTime       @map("start_ts")
  endTs           DateTime       @map("end_ts")
  durationMs      Int            @map("duration_ms")
  device          Json? // { type, ua, viewport }
  trafficSource   Json?          @map("traffic_source") // { utm, fbclid, gclid, referrer }
  landingPage     String?        @map("landing_page")
  keyframes       Json // array from keyframeExtractor
  signals         Json // aggregates from recordingSignalExtractor
  ecommerceEvents Json           @map("ecommerce_events") // add_to_cart, purchase, etc.
  outcome         SessionOutcome @default(STILL_BROWSING)
  cartValueAtEnd  Float?         @map("cart_value_at_end")
  orderId         String?        @map("order_id")
  aiAnalysis      Json?          @map("ai_analysis") // filled by Phase 6 LLM reasoning
  aiAnalyzedAt    DateTime?      @map("ai_analyzed_at")
  rawErasedAt     DateTime?      @map("raw_erased_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, personId])
  @@index([accountId, startTs])
  @@index([accountId, outcome])
  @@index([accountId, orderId])
  @@map("session_packets")
}

// ─── BRI Phase 7: Person ──────────────────────────────────────────────────────
// Aggregates multiple visitorIds (userKeys) that belong to the same real person.
// Built incrementally by personResolver.js after each SessionPacket is analyzed.

model Person {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  visitorIds   String[] @map("visitor_ids") // userKeys confirmed to be this person
  emailHashes  String[] @map("email_hashes")
  phoneHashes  String[] @map("phone_hashes")
  customerIds  String[] @map("customer_ids") // platform customer IDs (Shopify, Woo)
  firstSeenAt  DateTime @map("first_seen_at")
  lastSeenAt   DateTime @map("last_seen_at")
  sessionCount Int      @default(0) @map("session_count")
  orderCount   Int      @default(0) @map("order_count")
  totalSpent   Float    @default(0) @map("total_spent")

  account  Account         @relation(fields: [accountId], references: [accountId], onDelete: Cascade)
  analysis PersonAnalysis?

  @@index([accountId])
  @@map("people")
}

// ─── BRI Phase 8: PersonAnalysis ─────────────────────────────────────────────
// Cross-session AI profile per Person. Re-computed after each new SessionPacket.
// Rate-limited to once per person per day.

model PersonAnalysis {
  id               String   @id @default(uuid())
  personId         String   @unique @map("person_id")
  accountId        String   @map("account_id")
  tier             String? // vip | returning | new | at_risk
  behaviorSummary  String?  @map("behavior_summary")
  conversionProb   Float?   @map("conversion_probability")
  preferredChannel String?  @map("preferred_channel")
  nextBestAction   Json?    @map("next_best_action")
  retentionInsight String?  @map("retention_insight")
  ltvEstimate      Float?   @map("ltv_estimate")
  confidence       Float?
  sessionCount     Int      @default(0) @map("session_count")
  lastSessionId    String?  @map("last_session_id")
  analyzedAt       DateTime @default(now()) @map("analyzed_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("person_analysis")
}

// ─── Workspaces ───────────────────────────────────────────────────────────────

model UserMirror {
  id    String @id
  email String @unique

  firstName       String?
  lastName        String?
  jobTitle        String?
  primaryFocus    PrimaryFocus?
  profilePhotoUrl String?

  defaultWorkspaceId String?

  syncedAt DateTime @default(now()) @updatedAt

  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  defaultWorkspace Workspace?        @relation("UserDefaultWorkspace", fields: [defaultWorkspaceId], references: [id])

  @@index([email])
}

model Workspace {
  id               String            @id @default(uuid())
  slug             String            @unique
  name             String
  icon             WorkspaceIcon     @default(SHOPPING_BAG)
  industryVertical IndustryVertical?

  ownerUserId String

  plan             String  @default("gratis")
  stripeCustomerId String?

  onboardingComplete Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner           UserMirror            @relation("WorkspaceOwner", fields: [ownerUserId], references: [id])
  defaultForUsers UserMirror[]          @relation("UserDefaultWorkspace")
  members         WorkspaceMember[]
  invitations     WorkspaceInvitation[]
  accounts        Account[]

  @@index([ownerUserId])
  @@index([deletedAt])
}

model WorkspaceMember {
  id          String @id @default(uuid())
  workspaceId String
  userId      String

  role   WorkspaceRole @default(MEMBER)
  status MemberStatus  @default(ACTIVE)

  invitedBy    String?
  invitedAt    DateTime?
  joinedAt     DateTime  @default(now())
  lastActiveAt DateTime?

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      UserMirror @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model WorkspaceInvitation {
  id          String        @id @default(uuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(MEMBER)

  tokenHash String @unique
  invitedBy String

  expiresAt  DateTime
  acceptedAt DateTime?
  declinedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([workspaceId])
}
