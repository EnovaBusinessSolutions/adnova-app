{
  "name": "adnova-functional-app-dash-links-final-clean",
  "version": "1.0.0",
  "private": true,
  "main": "backend/index.js",
  "scripts": {
    "start": "node backend/index.js",
    "worker:mcp": "node backend/workers/mcpWorker.js",
    "build:dashboard": "npm --prefix dashboard-src ci && npm --prefix dashboard-src run build",
    "build": "npm run build:dashboard && npm run prisma:generate",
    "test": "jest backend/mcp/__tests__/ --verbose",
    "test:mcp": "jest backend/mcp/__tests__/ --verbose",
    "test:shopify-session": "node scripts/shopify-session-smoke.js",
    "seed:oauth-client": "node backend/scripts/seed-oauth-client.js",
    "mcp:smoke:staging": "node scripts/mcp-staging-smoke.js",
    "prisma:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=backend/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=backend/prisma/schema.prisma --skip-generate",
    "db:backfill:layer45": "node backend/scripts/backfill-layer45.js",
    "db:pc:check": "node scripts/platform-connections-dedupe.js --check",
    "db:pc:dedupe": "node scripts/platform-connections-dedupe.js --apply"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^6.19.2",
    "@shopify/shopify-api": "^11.12.0",
    "archiver": "^7.0.1",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bullmq": "^5.70.2",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.18",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "facturapi": "^4.10.0",
    "google-auth-library": "^10.3.0",
    "googleapis": "^153.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.15.0",
    "ngrok": "^5.0.0-beta.2",
    "nodemailer": "^7.0.5",
    "openai": "^5.22.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.4.1",
    "puppeteer": "^24.39.1",
    "qs": "^6.14.0",
    "stripe": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@shopify/app-bridge": "^3.7.10",
    "@types/node": "^25.0.10",
    "jest": "^30.3.0",
    "typescript": "^5.9.3"
  }
}
